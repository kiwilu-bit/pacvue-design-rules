## 七、完整 HTML 模板

```html
<!-- Filter Bar: flex-col, align-items-end -->
<div class="filter-bar">

  <!-- 筛选条件区 -->
  <div class="filter-conditions">

    <!-- Row 1: [Filters+Custom] [Cond] [Cond] [Cond] -->
    <div class="filter-row">
      <!-- Filters + Custom 共占 1 格 -->
      <div class="filter-quick">
        <button class="btn-filter">Filters</button>
        <button class="btn-filter">Custom</button>
      </div>

      <!-- 普通单选/多选条件 -->
      <div class="filter-cond">
        <span class="filter-cond-label">Vendor</span>
        <span class="filter-divider"></span>
        <span class="filter-cond-value has-value">Dial Corporation</span>
        <span class="filter-arrow">↓</span>
      </div>

      <!-- 文本搜索条件 -->
      <div class="filter-cond">
        <span class="filter-cond-label">Name</span>
        <span class="filter-divider"></span>
        <input class="filter-text-input" placeholder="Search..." />
      </div>

      <!-- 日期范围条件 -->
      <div class="filter-cond">
        <span class="filter-cond-label">Date</span>
        <span class="filter-divider"></span>
        <span class="filter-date-value">📅 Select range</span>
        <span class="filter-arrow">↓</span>
      </div>
    </div><!-- /Row 1 -->

    <!-- Row 2（如有更多条件） -->
    <div class="filter-row">
      <div class="filter-cond">...</div>
      <!-- 空格自动由 grid 填充，无需占位 div -->
    </div>

  </div><!-- /.filter-conditions -->

  <!-- Search + Clear：独占最后一行，align-items:flex-end 自动右对齐 -->
  <div class="filter-actions">
    <button class="btn-search">🔍 Search</button>
    <button class="btn-clear">⌫</button>
  </div>

</div>
```

