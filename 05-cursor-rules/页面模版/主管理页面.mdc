  /* ── Checkbox & Selection Logic ──────────────────────────── */
  const selectedRows = new Set(['1']);
  function setCheckboxState(cb, state) { cb.classList.remove('checked','indeterminate','disabled'); if (state!=='unchecked') cb.classList.add(state); }
  function syncHeaderCheckbox() { const headerCb=document.getElementById('headerCb'); if(!headerCb) return; const allRows=document.querySelectorAll('#state-normal tbody tr[data-row]'); const total=allRows.length; const selected=selectedRows.size; if(selected===0)setCheckboxState(headerCb,'unchecked'); else if(selected===total)setCheckboxState(headerCb,'checked'); else setCheckboxState(headerCb,'indeterminate'); }
  function syncBulkButton() { const btn=document.getElementById('bulkBtn'); if(!btn) return; if(selectedRows.size>0){btn.classList.add('active');}else{btn.classList.remove('active','open');} }
  function toggleRow(cb) { const row=cb.closest('tr'); const rowId=row.dataset.row; if(selectedRows.has(rowId)){selectedRows.delete(rowId);row.classList.remove('selected');setCheckboxState(cb,'unchecked');}else{selectedRows.add(rowId);row.classList.add('selected');setCheckboxState(cb,'checked');} syncHeaderCheckbox(); syncBulkButton(); }
  function toggleAll(headerCb) { const allRows=document.querySelectorAll('#state-normal tbody tr[data-row]'); const isAll=selectedRows.size===allRows.length; allRows.forEach(row=>{const rowId=row.dataset.row;const cb=row.querySelector('.cb');if(isAll){selectedRows.delete(rowId);row.classList.remove('selected');setCheckboxState(cb,'unchecked');}else{selectedRows.add(rowId);row.classList.add('selected');setCheckboxState(cb,'checked');}}); syncHeaderCheckbox(); syncBulkButton(); }
  (function initSelection() { const allRows=document.querySelectorAll('#state-normal tbody tr[data-row]'); allRows.forEach(row=>{const rowId=row.dataset.row;const cb=row.querySelector('.cb');if(selectedRows.has(rowId)){row.classList.add('selected');setCheckboxState(cb,'checked');}else{row.classList.remove('selected');setCheckboxState(cb,'unchecked');}}); syncHeaderCheckbox(); syncBulkButton(); })();

  /* ── Bulk Operation ──────────────────────────────────────── */
  function toggleBulkDropdown(btn) { if (!btn.classList.contains('active')) return; btn.classList.toggle('open'); }
  function bulkAction(action) { const count=selectedRows.size; alert(`${action==='delete'?'Delete':'Update'} ${count} selected item(s)`); document.getElementById('bulkBtn').classList.remove('open'); }

  /* ── Row actions ─────────────────────────────────────────── */
  function toggleMenu(btn) { const menu=btn.nextElementSibling; const isOpen=menu.classList.contains('open'); document.querySelectorAll('.action-menu.open').forEach(m=>m.classList.remove('open')); if(!isOpen) menu.classList.add('open'); }
  document.addEventListener('click', e => { if (!e.target.closest('.menu-row')) document.querySelectorAll('.action-menu.open').forEach(m=>m.classList.remove('open')); if (!e.target.closest('#bulkBtn')) document.getElementById('bulkBtn')?.classList.remove('open'); });

  /* ── Delete Modal ─────────────────────────────────────────── */
  function openDeleteModal(isLinked) {
    document.getElementById('deleteModal').classList.add('open');
    document.getElementById('linkedWarning').style.display = isLinked ? 'flex' : 'none';
    const btn = document.getElementById('deleteBtn');
    if (isLinked) {
      btn.style.display = 'none';
      let disabled = document.getElementById('deleteBtnDisabled');
      if (!disabled) { disabled = document.createElement('button'); disabled.id='deleteBtnDisabled'; disabled.className='btn-danger-disabled'; disabled.textContent='Delete'; btn.parentNode.insertBefore(disabled, btn); }
      disabled.style.display = 'block';
    } else {
      btn.style.display = 'block';
      const disabled = document.getElementById('deleteBtnDisabled');
      if (disabled) disabled.style.display = 'none';
    }
  }
  function closeDeleteModal() { document.getElementById('deleteModal').classList.remove('open'); }
