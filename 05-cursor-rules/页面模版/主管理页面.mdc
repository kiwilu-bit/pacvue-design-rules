## 六、完整 HTML 原型源码

> 可直接复制整段内容另存为 `.html` 文件在浏览器打开，无任何外部依赖。
> 修改时：将 Catalog / Catalogs 替换为目标实体名称，列定义按 PRD 调整。

```html
<!DOCTYPE html>
<html lang="en" data-theme="blue" data-state="normal">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Catalogs — Pacvue</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ── Pacvue Design Tokens ──────────────────────────────────── */
    :root,
    [data-theme="blue"] {
      --pcv-brand:          #0253b6;
      --pcv-brand-rgb:      2, 83, 182;
      --pcv-nav-bg:         #12143c;
      --pcv-icon-default:   #e7e4ee;
      --pcv-icon-selected:  #66a8ff;
      --pcv-hover-bg:       #f2f6fb;
      --pcv-selected-bg:    #d9e5f4;
    }
    [data-theme="orange"] {
      --pcv-brand:          #ff9f43;
      --pcv-brand-rgb:      255, 159, 67;
      --pcv-nav-bg:         #333333;
      --pcv-icon-default:   #e7e4ee;
      --pcv-icon-selected:  #ff9f43;
      --pcv-hover-bg:       #fffaf6;
      --pcv-selected-bg:    #fff1e3;
    }
    :root {
      --pcv-success:        #28c76f;
      --pcv-warning:        #ff9f43;
      --pcv-error:          #ea5455;
      --pcv-neutral:        #82858b;
      --pcv-text-primary:   #45464f;
      --pcv-text-secondary: #66666c;
      --pcv-text-muted:     #82858b;
      --pcv-text-disabled:  #b2b2b8;
      --pcv-bg:             #f2f3f6;
      --pcv-surface:        #ffffff;
      --pcv-border:         #edeef1;
      --pcv-border-input:   #dedfe3;
      --pcv-scrollbar:      #d2d4d9;
      --radius-sm:          4px;
      --radius-md:          6px;
      --font-sans:          Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--font-sans);
      font-size: 14px;
      color: var(--pcv-text-primary);
      background: var(--pcv-bg);
      min-height: 100vh;
    }

    /* ── Dev Controls ──────────────────────────────────────────── */
    .dev-controls {
      position: fixed; top: 12px; right: 16px; z-index: 9999;
      display: flex; gap: 6px; align-items: center;
      background: rgba(255,255,255,.92);
      border: 1px solid var(--pcv-border-input);
      border-radius: var(--radius-md);
      padding: 6px 10px;
      box-shadow: 0 2px 12px rgba(0,0,0,.1);
    }
    .dev-btn {
      height: 28px; padding: 0 12px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--pcv-border-input);
      background: var(--pcv-surface);
      font-family: var(--font-sans); font-size: 12px; font-weight: 500;
      color: var(--pcv-text-secondary); cursor: pointer; transition: all .15s;
    }
    .dev-btn:hover { border-color: var(--pcv-brand); color: var(--pcv-brand); }
    .dev-btn.active { background: var(--pcv-brand); border-color: var(--pcv-brand); color: #fff; }
    .dev-sep { width: 1px; height: 16px; background: var(--pcv-border-input); margin: 0 2px; }
    .dev-label { font-size: 11px; color: var(--pcv-text-muted); white-space: nowrap; }

    /* ── App Shell ─────────────────────────────────────────────── */
    .app-shell { display: flex; min-height: 100vh; }

    /* ── Sidebar (62px) ────────────────────────────────────────── */
    .sidebar {
      width: 62px; background: var(--pcv-nav-bg);
      display: flex; flex-direction: column; align-items: center;
      padding: 12px 8px; gap: 4px;
      position: fixed; inset: 0 auto 0 0; z-index: 300;
      transition: background .3s;
    }
    .sidebar-logo {
      width: 36px; height: 36px; border-radius: var(--radius-md);
      border: 1px solid rgba(255,255,255,.35);
      display: grid; place-items: center;
      color: #fff; font-weight: 700; font-size: 13px; margin-bottom: 8px;
    }
    .sidebar-sep { width: 32px; height: 1px; background: rgba(255,255,255,.1); margin: 4px 0; }
    .nav-item {
      width: 40px; height: 40px; border-radius: var(--radius-md);
      display: grid; place-items: center;
      color: var(--pcv-icon-default); cursor: pointer; transition: all .15s;
      position: relative;
    }
    .nav-item:hover { background: rgba(255,255,255,.08); color: #fff; }
    .nav-item.active { background: rgba(var(--pcv-brand-rgb),.15); color: var(--pcv-icon-selected); }
    .nav-item svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }
    .nav-item::after {
      content: attr(data-label);
      position: absolute; left: calc(100% + 8px); top: 50%; transform: translateY(-50%);
      background: #1a1d23; color: #fff; font-size: 11px; white-space: nowrap;
      padding: 4px 8px; border-radius: var(--radius-sm);
      opacity: 0; pointer-events: none; transition: opacity .15s;
    }
    .nav-item:hover::after { opacity: 1; }

    /* ── Main Area ─────────────────────────────────────────────── */
    .main-area {
      margin-left: 62px;
      flex: 1;
      min-width: 0;
      max-width: calc(100vw - 62px);
      overflow-x: hidden;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    /* ── Top Nav (56px) ────────────────────────────────────────── */
    .top-nav {
      height: 56px; background: var(--pcv-brand);
      box-shadow: 0 4px 24px rgba(0,0,0,.06);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px; position: sticky; top: 0; z-index: 200;
      transition: background .3s;
    }
    .top-nav-left { color: #fff; font-size: 14px; font-weight: 600; }
    .top-nav-right { display: flex; align-items: center; gap: 14px; }
    .nav-action-btn {
      width: 32px; height: 32px; border-radius: var(--radius-md);
      display: grid; place-items: center;
      color: rgba(255,255,255,.8); cursor: pointer; border: 0; background: transparent;
      transition: background .15s;
    }
    .nav-action-btn:hover { background: rgba(255,255,255,.15); color: #fff; }
    .nav-action-btn svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .avatar {
      width: 28px; height: 28px; border-radius: 50%;
      background: rgba(255,255,255,.22); border: 1.5px solid rgba(255,255,255,.45);
      display: grid; place-items: center;
      color: #fff; font-size: 11px; font-weight: 600; cursor: pointer;
    }

    /* ── Page Title Bar (Type 1: single-level, 56px) ───────────── */
    .page-title-bar {
      height: 56px; background: #fff;
      box-shadow: 0 2px 4px rgba(228,228,228,.5);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px;
      position: sticky; top: 56px; z-index: 80;
    }
    .page-title {
      font-size: 20px; font-weight: 600; color: #45464f;
    }

    /* ── Page Content ──────────────────────────────────────────── */
    .page-content {
      flex: 1;
      padding: 16px 24px 24px;
      display: flex;
      flex-direction: column;
      gap: 0;
      min-width: 0;
      width: 100%;
    }

    /* ── Table Card ────────────────────────────────────────────── */
    .table-card {
      background: var(--pcv-surface);
      border-radius: var(--radius-md);
      display: flex;
      flex-direction: column;
      min-width: 0;
      width: 100%;
    }

    /* ── FILTER BAR ─────────────────────────────────────────────── */
    .filter-bar {
      padding: 16px 24px;
      border-bottom: 1px solid var(--pcv-border);
      background: var(--pcv-surface);
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 16px;
    }
    .filter-conditions { width: 100%; display: flex; flex-direction: column; gap: 16px; }
    .filter-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; width: 100%; }
    .filter-quick { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .btn-filter {
      height: 36px; padding: 0 12px;
      border: 1px solid var(--pcv-brand); border-radius: var(--radius-sm);
      background: var(--pcv-surface); color: var(--pcv-brand);
      font-family: var(--font-sans); font-size: 14px; font-weight: 500;
      display: flex; align-items: center; justify-content: center; gap: 6px;
      cursor: pointer; transition: background .15s; white-space: nowrap;
    }
    .btn-filter:hover { background: rgba(var(--pcv-brand-rgb),.06); }
    .btn-filter svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
    .filter-cond {
      height: 36px; width: 100%;
      border: 1px solid var(--pcv-border-input); border-radius: var(--radius-sm);
      display: flex; align-items: center;
      overflow: hidden; cursor: pointer;
      background: var(--pcv-surface); transition: border-color .15s;
    }
    .filter-cond:hover { border-color: var(--pcv-brand); }
    .filter-cond.date-cond { overflow: visible; }
    .filter-cond-label {
      padding: 0 12px; font-size: 14px; font-weight: 500;
      color: var(--pcv-text-primary); white-space: nowrap; flex-shrink: 0;
    }
    .filter-divider { width: 1px; height: 16px; background: var(--pcv-border-input); flex-shrink: 0; }
    .filter-cond-value {
      flex: 1; min-width: 0; padding: 0 8px;
      font-size: 14px; color: var(--pcv-text-muted);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .filter-cond-value.has-value { color: var(--pcv-text-secondary); }
    .filter-cond-value.active { color: var(--pcv-brand); font-weight: 500; }
    .filter-arrow { padding: 0 10px 0 4px; flex-shrink: 0; display: flex; align-items: center; color: var(--pcv-text-muted); }
    .filter-arrow svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }
    .filter-text-input {
      flex: 1; min-width: 0; border: none; outline: none; background: transparent;
      font-family: var(--font-sans); font-size: 14px; color: var(--pcv-text-secondary);
      padding: 0 8px;
    }
    .filter-text-input::placeholder { color: #b2b2b8; }

    /* 日期范围条件框 */
    .filter-cond.date-cond.active { border-color: var(--pcv-brand); }
    .filter-date-text { flex: 1; min-width: 0; font-size: 14px; color: #b2b2b8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .filter-date-text.has-value { color: #66666c; }
    .filter-date-clear { display: none; width: 16px; height: 16px; flex-shrink: 0; cursor: pointer; color: #b2b2b8; transition: color .12s; }
    .filter-date-clear:hover { color: var(--pcv-brand); }
    .filter-date-clear svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .filter-cond.has-value .filter-date-clear { display: flex; align-items: center; }
    .filter-cal-icon { flex-shrink: 0; width: 20px; height: 20px; margin-right: 10px; display: flex; align-items: center; justify-content: center; color: #dedfe3; }
    .filter-cond.date-cond:hover .filter-cal-icon,
    .filter-cond.date-cond.active .filter-cal-icon { color: var(--pcv-brand); }
    .filter-cal-icon svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }

    /* 日期选择面板 — fixed 定位，JS 计算位置 */
    .date-picker-panel {
      display: none; position: fixed; z-index: 9000;
      background: #ffffff; border-radius: 6px;
      box-shadow: 0 10px 24px 0 rgba(0,0,0,.12);
      border: 1px solid #edeef1; min-width: 580px; padding: 0;
    }
    .date-picker-panel.open { display: flex; }
    .date-shortcuts { width: 200px; border-right: 1px solid #edeef1; padding: 8px 0; flex-shrink: 0; }
    .date-shortcut { height: 36px; padding: 0 16px; display: flex; align-items: center; font-size: 14px; color: #45464f; cursor: pointer; transition: background .1s; }
    .date-shortcut:hover { background: rgba(var(--pcv-brand-rgb),.06); }
    .date-shortcut.selected { background: var(--pcv-brand); color: #fff; font-weight: 500; border-radius: 4px; margin: 0 8px; padding: 0 8px; }
    .date-calendars { flex: 1; display: flex; flex-direction: column; }
    .date-months { display: flex; padding: 12px 16px 8px; gap: 16px; }
    .date-month { flex: 1; }
    .date-month-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; padding: 0 4px; }
    .date-month-title { font-size: 14px; font-weight: 500; color: #5e5873; }
    .date-nav { width: 24px; height: 24px; border-radius: 4px; display: grid; place-items: center; cursor: pointer; color: #6e6b7b; transition: background .1s; }
    .date-nav:hover { background: rgba(var(--pcv-brand-rgb),.08); }
    .date-nav svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .date-weekdays { display: grid; grid-template-columns: repeat(7,1fr); margin-bottom: 4px; }
    .date-weekday { height: 28px; display: grid; place-items: center; font-size: 12px; color: #6e6b7b; }
    .date-days { display: grid; grid-template-columns: repeat(7,1fr); }
    .date-day { width: 36px; height: 36px; display: grid; place-items: center; font-size: 14px; color: #6e6b7b; cursor: pointer; border-radius: 18px; transition: background .1s; }
    .date-day:hover { background: rgba(var(--pcv-brand-rgb),.15); }
    .date-day.other-month { color: #b9b9c3; }
    .date-day.today { background: var(--pcv-brand); color: #fff; }
    .date-day.selected { background: var(--pcv-brand); color: #fff; }
    .date-day.in-range { background: rgba(var(--pcv-brand-rgb),.15); border-radius: 0; }
    .date-day.range-start { border-radius: 18px 0 0 18px; background: var(--pcv-brand); color: #fff; }
    .date-day.range-end   { border-radius: 0 18px 18px 0; background: var(--pcv-brand); color: #fff; }
    .date-day.disabled { color: #b9b9c3; cursor: not-allowed; }
    .date-day.disabled:hover { background: transparent; }
    .date-footer { display: flex; align-items: center; justify-content: flex-end; gap: 12px; padding: 12px 16px; border-top: 1px solid #edeef1; }
    .date-btn-cancel { height: 32px; padding: 0 16px; border: 1px solid #dedfe3; border-radius: 4px; background: #fff; font-size: 14px; color: #66666c; cursor: pointer; }
    .date-btn-cancel:hover { border-color: var(--pcv-brand); color: var(--pcv-brand); }
    .date-btn-apply { height: 32px; padding: 0 16px; border: none; border-radius: 4px; background: var(--pcv-brand); font-size: 14px; color: #fff; cursor: pointer; font-weight: 500; }
    .date-btn-apply:hover { opacity: .88; }

    /* Search + Clear 按钮行 */
    .filter-actions { display: flex; align-items: center; gap: 16px; }
    .btn-search {
      height: 36px; padding: 0 20px;
      background: var(--pcv-brand); border: 1px solid var(--pcv-brand); border-radius: var(--radius-md);
      color: #fbfbfb; font-family: var(--font-sans); font-size: 14px; font-weight: 500;
      display: flex; align-items: center; gap: 8px; cursor: pointer; transition: opacity .15s;
    }
    .btn-search:hover { opacity: .88; }
    .btn-search svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .btn-clear {
      width: 36px; height: 36px;
      border: 1px solid var(--pcv-border-input); border-radius: var(--radius-md);
      background: var(--pcv-surface); display: grid; place-items: center;
      cursor: pointer; transition: all .15s; color: var(--pcv-text-muted);
    }
    .btn-clear:hover { border-color: var(--pcv-brand); color: var(--pcv-brand); }
    .btn-clear svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }

    /* ── TOOLBAR (68px) ─────────────────────────────────────────── */
    .toolbar { height: 68px; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--pcv-border); background: var(--pcv-surface); }
    .toolbar-left { display: flex; align-items: center; gap: 16px; }
    .toolbar-right { display: flex; align-items: center; gap: 16px; }
    .btn-primary {
      height: 36px; padding: 0 20px;
      background: var(--pcv-brand); border: none; border-radius: var(--radius-sm);
      color: #fff; font-family: var(--font-sans); font-size: 14px; font-weight: 500;
      display: flex; align-items: center; gap: 8px; cursor: pointer; transition: opacity .15s;
    }
    .btn-primary:hover { opacity: .88; }
    .btn-primary svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .btn-bulk {
      height: 36px; padding: 0 16px;
      background: rgba(130,133,139,.05);
      border: 1px solid var(--pcv-border-input); border-radius: var(--radius-sm);
      color: var(--pcv-text-disabled); font-family: var(--font-sans); font-size: 14px; font-weight: 500;
      display: flex; align-items: center; gap: 8px; cursor: not-allowed; position: relative; transition: all .12s;
    }
    .btn-bulk svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }
    .btn-bulk.active { background: #ffffff; border-color: var(--pcv-brand); color: var(--pcv-brand); cursor: pointer; }
    .btn-bulk.active:hover { background: rgba(var(--pcv-brand-rgb), .06); }
    .bulk-dropdown { display: none; position: absolute; top: calc(100% + 6px); left: 0; min-width: 180px; background: #fff; border: 1px solid #edeef1; border-radius: 6px; box-shadow: 0 4px 16px rgba(0,0,0,.10); z-index: 500; padding: 4px 0; }
    .btn-bulk.active.open .bulk-dropdown { display: block; }
    .bulk-item { height: 36px; padding: 0 16px; display: flex; align-items: center; gap: 8px; font-size: 14px; color: #45464f; cursor: pointer; transition: background .1s; }
    .bulk-item:hover { background: rgba(var(--pcv-brand-rgb), .06); color: var(--pcv-brand); }
    .bulk-item svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }
    .tool-icon { width: 24px; height: 24px; display: grid; place-items: center; cursor: pointer; color: var(--pcv-text-secondary); transition: color .15s; }
    .tool-icon:hover { color: var(--pcv-brand); }
    .tool-icon svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }
    .tool-sep { width: 2px; height: 24px; background: var(--pcv-scrollbar); border-radius: 2px; }

    /* ── HORIZONTAL SCROLLBAR (16px, decorative) ──────────────── */
    .h-scroll-track { height: 16px; background: #f4f5f6; border-bottom: 1px solid var(--pcv-border); overflow: hidden; position: relative; }
    .h-scroll-thumb { position: absolute; top: 3px; left: 24px; width: 280px; height: 10px; background: var(--pcv-scrollbar); border-radius: 5px; }

    /* ── TABLE ──────────────────────────────────────────────────── */
    .table-wrap { overflow-x: auto; width: 100%; min-width: 0; position: relative; }
    table { width: 100%; min-width: 1400px; border-collapse: separate; border-spacing: 0; }
    thead tr { height: 48px; background: var(--pcv-surface); border-bottom: 1px solid var(--pcv-border); }
    th { height: 48px; padding: 0 16px; font-size: 13px; font-weight: 500; color: #45464f; text-align: left; white-space: nowrap; border-right: none; background: #fff; }
    th:first-child { padding-left: 16px; width: 44px; }
    th:last-child { width: 32px; padding: 0; }

    /* 固定列 */
    th:nth-child(1), td:nth-child(1) { position: sticky; left: 0; z-index: 10; background: #fff; }
    th:nth-child(2), td:nth-child(2) { position: sticky; left: 44px; z-index: 10; background: #fff; }
    th:last-child, td:last-child { position: sticky; right: 0; z-index: 10; background: #fff; width: 32px; padding: 0; }

    /* 固定列阴影 */
    .table-wrap.can-scroll-right th:nth-child(2)::after,
    .table-wrap.can-scroll-right td:nth-child(2)::after {
      content: ''; position: absolute; top: 0; right: -10px; bottom: 0; width: 10px;
      background: linear-gradient(to right, rgba(0,0,0,0.07), transparent); pointer-events: none;
    }
    .table-wrap.can-scroll-left th:last-child::before,
    .table-wrap.can-scroll-left td:last-child::before {
      content: ''; position: absolute; top: 0; left: -10px; bottom: 0; width: 10px;
      background: linear-gradient(to left, rgba(0,0,0,0.07), transparent); pointer-events: none;
    }

    /* 固定列背景：必须用 color-mix 实色，不可用 rgba */
    tbody tr:hover td:nth-child(1), tbody tr:hover td:nth-child(2), tbody tr:hover td:last-child {
      background: color-mix(in srgb, var(--pcv-brand) 4%, #ffffff);
    }
    tbody tr.selected td:nth-child(1), tbody tr.selected td:nth-child(2), tbody tr.selected td:last-child {
      background: color-mix(in srgb, var(--pcv-brand) 6%, #ffffff);
    }

    /* 排序图标 */
    .th-sort { display: inline-flex; align-items: center; gap: 4px; cursor: pointer; }
    .th-sort:hover { color: var(--pcv-brand); }
    .sort-icon { display: inline-flex; flex-direction: column; gap: 1px; width: 12px; }
    .sort-icon span { display: block; width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; }
    .sort-icon .sort-up { border-bottom: 5px solid var(--pcv-text-muted); }
    .sort-icon .sort-dn { border-top: 5px solid var(--pcv-text-muted); }
    .sort-icon.asc .sort-up { border-bottom-color: var(--pcv-brand); }
    .sort-icon.desc .sort-dn { border-top-color: var(--pcv-brand); }

    /* 数据行 (52px) */
    tbody tr { height: 52px; border-bottom: 1px solid var(--pcv-border); transition: background .12s; }
    tbody tr:hover { background: rgba(var(--pcv-brand-rgb),.04); }
    tbody tr.selected { background: rgba(var(--pcv-brand-rgb),.06); }
    tbody tr:last-child { border-bottom: none; }
    td { height: 52px; padding: 0 16px; font-size: 14px; color: var(--pcv-text-secondary); vertical-align: middle; white-space: nowrap; }
    td:first-child { padding-left: 16px; }
    td:last-child { padding: 0; }

    /* 单元格内容样式 */
    .cell-bizname { display: flex; flex-direction: column; gap: 2px; }
    .cell-bizname .name { font-size: 14px; color: var(--pcv-text-primary); font-weight: 500; max-width: 180px; overflow: hidden; text-overflow: ellipsis; }
    .cell-bizname .biz-id { font-size: 12px; color: var(--pcv-text-muted); }
    .cell-link { color: var(--pcv-brand); cursor: pointer; font-weight: 500; }
    .cell-link:hover { text-decoration: underline; }
    .status-dot { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; cursor: pointer; }
    .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .dot-green  { background: var(--pcv-success); }
    .dot-orange { background: var(--pcv-warning); }
    .dot-red    { background: var(--pcv-error); }
    .dot-gray   { background: var(--pcv-neutral); }
    .status-dot svg { width: 10px; height: 10px; stroke: var(--pcv-text-muted); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .chip { display: inline-flex; align-items: center; height: 22px; padding: 0 8px; border-radius: 11px; font-size: 12px; font-weight: 500; white-space: nowrap; }
    .chip-success { background: rgba(40,199,111,.1); color: var(--pcv-success); }
    .chip-failed  { background: rgba(234,84,85,.1);  color: var(--pcv-error); }
    .chip-processing { background: rgba(255,159,67,.1); color: #e08b2a; }
    .chip-none    { background: rgba(130,133,139,.08); color: var(--pcv-text-muted); }
    .tag { display: inline-flex; align-items: center; height: 22px; padding: 0 8px; border-radius: var(--radius-sm); font-size: 12px; font-weight: 500; white-space: nowrap; }
    .tag-feed { background: rgba(2,83,182,.08); color: #0253b6; }
    .tag-bulk { background: rgba(130,133,139,.1); color: var(--pcv-text-secondary); }
    .text-right { text-align: right; }

    /* 多选框 */
    .cb { width: 18px; height: 18px; border-radius: 3px; border: 1.5px solid #dedfe3; background: #ffffff; display: grid; place-items: center; cursor: pointer; flex-shrink: 0; transition: border-color .12s, background .12s; position: relative; }
    .cb:hover:not(.disabled) { border-color: var(--pcv-brand); }
    .cb.checked { background: var(--pcv-brand); border-color: var(--pcv-brand); }
    .cb.checked::after { content: ''; width: 8px; height: 6px; border-left: 2px solid #fff; border-bottom: 2px solid #fff; transform: rotate(-45deg) translate(1px, 0px); display: block; }
    .cb.indeterminate { background: #ffffff; border-color: var(--pcv-brand); }
    .cb.indeterminate::after { content: ''; width: 8px; height: 2px; background: var(--pcv-brand); border-radius: 1px; display: block; }
    .cb.disabled { background: #f4f5f6; border-color: #dedfe3; cursor: not-allowed; }
    .cb.disabled.checked::after { border-color: #b2b2b8; }
    .cb.disabled.indeterminate::after { background: #b2b2b8; }

    /* Row action menu */
    .more-btn { width: 32px; height: 52px; display: grid; place-items: center; cursor: pointer; color: var(--pcv-text-muted); transition: color .12s; }
    .more-btn:hover { color: var(--pcv-brand); }
    .more-btn svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .action-menu { position: absolute; right: 56px; top: 100%; background: var(--pcv-surface); border-radius: var(--radius-md); box-shadow: 0 4px 14px 4px rgba(0,0,0,.06); padding: 6px 0; min-width: 160px; z-index: 100; display: none; }
    .action-menu.open { display: block; }
    .menu-row { position: relative; }
    .menu-row:hover .action-menu { display: block; }
    .menu-item { height: 40px; padding: 0 20px; display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--pcv-text-secondary); cursor: pointer; transition: background .12s; }
    .menu-item:hover { background: rgba(var(--pcv-brand-rgb),.05); }
    .menu-item.danger { color: var(--pcv-error); }
    .menu-item.danger:hover { background: rgba(234,84,85,.05); }
    .menu-item.disabled { color: var(--pcv-text-disabled); cursor: not-allowed; }
    .menu-item.disabled:hover { background: transparent; }
    .menu-item svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }

    /* ── PAGINATION (64px) ──────────────────────────────────────── */
    .pagination { height: 64px; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--pcv-border); background: var(--pcv-surface); flex-shrink: 0; }
    .pagination-left { display: flex; align-items: center; gap: 4px; font-size: 14px; color: #6e6b7b; white-space: nowrap; }
    .page-size-select { height: 32px; padding: 0 28px 0 10px; border: 1px solid #d8d6de; border-radius: 5px; font-family: var(--font-sans); font-size: 14px; font-weight: 500; color: #5e5873; background: var(--pcv-surface); appearance: none; cursor: pointer; background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 6l4 4 4-4' stroke='%2366666C' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 6px center; outline: none; transition: border-color .15s; }
    .page-size-select:hover, .page-size-select:focus { border-color: var(--pcv-brand); }
    .pagination-right { display: flex; align-items: center; gap: 8px; }
    .page-btn { width: 32px; height: 32px; border-radius: var(--radius-sm); border: 1px solid var(--pcv-border-input); background: transparent; font-family: var(--font-sans); font-size: 14px; font-weight: 400; color: var(--pcv-text-secondary); display: grid; place-items: center; cursor: pointer; transition: border-color .12s, color .12s; flex-shrink: 0; line-height: 1; }
    .page-btn:hover { border-color: var(--pcv-brand); color: var(--pcv-brand); }
    .page-btn.active { border-color: var(--pcv-brand); color: var(--pcv-brand); font-weight: 500; }
    .page-btn.ellipsis { border-color: transparent; cursor: default; color: var(--pcv-text-muted); }
    .page-btn.ellipsis:hover { border-color: transparent; color: var(--pcv-text-muted); }
    .page-btn.nav svg { width: 16px; height: 16px; stroke: #66666c; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; }
    .page-btn.nav:hover svg { stroke: var(--pcv-brand); }
    .page-goto { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--pcv-text-secondary); white-space: nowrap; }
    .page-goto-input { width: 58px; height: 32px; border: 1px solid var(--pcv-border-input); border-radius: var(--radius-sm); text-align: center; font-family: var(--font-sans); font-size: 14px; font-weight: 500; color: var(--pcv-text-primary); background: var(--pcv-surface); outline: none; transition: border-color .15s; }
    .page-goto-input:focus { border-color: var(--pcv-brand); }

    /* ── PAGE STATE OVERLAYS ────────────────────────────────────── */
    .state-overlay { display: none; flex-direction: column; align-items: center; justify-content: center; padding: 80px 24px; gap: 16px; }
    .state-overlay.show { display: flex; }
    .state-icon { width: 64px; height: 64px; border-radius: 50%; display: grid; place-items: center; }
    .state-icon svg { width: 32px; height: 32px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
    .state-icon.loading { background: rgba(var(--pcv-brand-rgb),.08); color: var(--pcv-brand); animation: spin 1.2s linear infinite; }
    .state-icon.empty   { background: rgba(130,133,139,.08); color: var(--pcv-text-muted); }
    .state-icon.error   { background: rgba(234,84,85,.08); color: var(--pcv-error); }
    @keyframes spin { to { transform: rotate(360deg); } }
    .state-title { font-size: 16px; font-weight: 600; color: var(--pcv-text-primary); }
    .state-desc  { font-size: 14px; color: var(--pcv-text-muted); text-align: center; max-width: 360px; }
    .state-action { margin-top: 4px; }

    /* ── DELETE MODAL ───────────────────────────────────────────── */
    .modal-mask { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 500; align-items: center; justify-content: center; }
    .modal-mask.open { display: flex; }
    .modal { background: var(--pcv-surface); border-radius: var(--radius-md); width: 480px; box-shadow: 0 10px 40px rgba(0,0,0,.15); overflow: hidden; }
    .modal-header { height: 56px; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--pcv-border); }
    .modal-title { font-size: 16px; font-weight: 600; color: var(--pcv-text-primary); }
    .modal-close { width: 28px; height: 28px; display: grid; place-items: center; border-radius: var(--radius-sm); cursor: pointer; color: var(--pcv-text-muted); transition: all .12s; border: 0; background: transparent; }
    .modal-close:hover { background: var(--pcv-border); color: var(--pcv-text-primary); }
    .modal-close svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .modal-body { padding: 24px; }
    .modal-warning { display: flex; gap: 12px; align-items: flex-start; padding: 12px 16px; border-radius: var(--radius-md); background: rgba(234,84,85,.06); margin-bottom: 16px; }
    .modal-warning svg { width: 18px; height: 18px; stroke: var(--pcv-error); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; margin-top: 1px; }
    .modal-warning p { font-size: 14px; color: var(--pcv-text-secondary); line-height: 1.6; }
    .modal-warning strong { color: var(--pcv-error); }
    .modal-footer { height: 64px; padding: 0 24px; display: flex; align-items: center; justify-content: flex-end; gap: 12px; border-top: 1px solid var(--pcv-border); }
    .btn-cancel { height: 36px; padding: 0 20px; border: 1px solid var(--pcv-border-input); border-radius: var(--radius-sm); background: var(--pcv-surface); font-family: var(--font-sans); font-size: 14px; color: var(--pcv-text-secondary); cursor: pointer; transition: all .15s; }
    .btn-cancel:hover { border-color: var(--pcv-brand); color: var(--pcv-brand); }
    .btn-danger { height: 36px; padding: 0 20px; border: none; border-radius: var(--radius-sm); background: var(--pcv-error); font-family: var(--font-sans); font-size: 14px; font-weight: 500; color: #fff; cursor: pointer; transition: opacity .15s; }
    .btn-danger:hover { opacity: .88; }
    .btn-danger-disabled { height: 36px; padding: 0 20px; border: 1px solid var(--pcv-border-input); border-radius: var(--radius-sm); background: rgba(130,133,139,.05); font-family: var(--font-sans); font-size: 14px; color: var(--pcv-text-disabled); cursor: not-allowed; }
  </style>
</head>
<body>

<!-- Dev Controls（仅原型调试用，生产代码不包含） -->
<div class="dev-controls">
  <span class="dev-label">Theme:</span>
  <button class="dev-btn active" onclick="setTheme('blue', this)">Blue</button>
  <button class="dev-btn" onclick="setTheme('orange', this)">Orange</button>
  <div class="dev-sep"></div>
  <span class="dev-label">State:</span>
  <button class="dev-btn active" onclick="setState('normal', this)">Normal</button>
  <button class="dev-btn" onclick="setState('loading', this)">Loading</button>
  <button class="dev-btn" onclick="setState('empty', this)">Empty</button>
  <button class="dev-btn" onclick="setState('error', this)">Error</button>
  <div class="dev-sep"></div>
  <button class="dev-btn" onclick="openDeleteModal(false)">Delete Modal</button>
  <button class="dev-btn" onclick="openDeleteModal(true)">Delete (Linked)</button>
</div>

<div class="app-shell">

  <!-- Sidebar (62px) -->
  <nav class="sidebar">
    <div class="sidebar-logo">P</div>
    <div class="sidebar-sep"></div>
    <div class="nav-item" data-label="Dashboard">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
    </div>
    <div class="nav-item active" data-label="Advertising">
      <svg viewBox="0 0 24 24"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
    </div>
    <div class="nav-item" data-label="Analytics">
      <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
    </div>
    <div class="nav-item" data-label="Reports">
      <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    </div>
    <div class="sidebar-sep"></div>
    <div class="nav-item" data-label="Settings">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
    </div>
  </nav>

  <main class="main-area">

    <!-- Top Nav -->
    <div class="top-nav">
      <div class="top-nav-left">Reddit Advertising</div>
      <div class="top-nav-right">
        <button class="nav-action-btn"><svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg></button>
        <button class="nav-action-btn"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></button>
        <div class="avatar">KL</div>
      </div>
    </div>

    <!-- Page Title Bar (Type 1: single-level) -->
    <div class="page-title-bar">
      <div class="page-title">Catalogs</div>
    </div>

    <div class="page-content">
      <div class="table-card">

        <!-- Filter Bar -->
        <div class="filter-bar">
          <div class="filter-conditions">

            <!-- Row 1 -->
            <div class="filter-row">
              <div class="filter-quick">
                <button class="btn-filter">
                  <svg viewBox="0 0 24 24"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                  Filters
