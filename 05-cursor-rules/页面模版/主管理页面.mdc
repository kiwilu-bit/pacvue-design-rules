<script>
  /* Theme toggle */
  function setTheme(theme, btn) {
    document.documentElement.setAttribute('data-theme', theme);
    document.querySelectorAll('.dev-controls .dev-btn').forEach(b => {
      if (b.textContent === 'Blue' || b.textContent === 'Orange') b.classList.remove('active');
    });
    btn.classList.add('active');
  }

  /* State toggle */
  function setState(state, btn) {
    ['normal','loading','empty','error'].forEach(s => {
      const el = document.getElementById('state-' + s);
      if (el) el.style.display = (s === state) ? (s === 'normal' ? 'block' : 'flex') : 'none';
    });
    document.querySelectorAll('.dev-controls .dev-btn').forEach(b => {
      if (['Normal','Loading','Empty','Error'].includes(b.textContent)) b.classList.remove('active');
    });
    btn.classList.add('active');
    const toolbar = document.querySelector('.toolbar');
    const scrollbar = document.querySelector('.h-scroll-track');
    if (state === 'normal') {
      toolbar.style.display = 'flex';
      scrollbar.style.display = 'block';
    } else {
      toolbar.style.display = 'none';
      scrollbar.style.display = 'none';
    }
  }

  /* ── Date Range Picker ──────────────────────────────────────── */
  const dateState = { open: false, start: null, end: null, viewYear: new Date().getFullYear(), viewMonth: new Date().getMonth() };
  const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const DAYS   = ['Su','Mo','Tu','We','Th','Fr','Sa'];
  function fmtDate(d) { if (!d) return ''; const m = String(d.getMonth()+1).padStart(2,'0'); const dd = String(d.getDate()).padStart(2,'0'); return `${m}/${dd}/${d.getFullYear()}`; }
  function isSameDay(a, b) { return a && b && a.getFullYear()===b.getFullYear() && a.getMonth()===b.getMonth() && a.getDate()===b.getDate(); }
  function renderMonth(year, month) {
    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month+1, 0).getDate();
    const today = new Date();
    let html = `<div class="date-month"><div class="date-month-header"><div class="date-nav" onclick="navMonth(-1)"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></div><span class="date-month-title">${MONTHS[month]} ${year}</span><div class="date-nav" onclick="navMonth(1)"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></div></div><div class="date-weekdays">${DAYS.map(d=>`<div class="date-weekday">${d}</div>`).join('')}</div><div class="date-days">`;
    for (let i=0; i<firstDay; i++) { const prevDate = new Date(year, month, -(firstDay-1-i)); html += `<div class="date-day other-month" onclick="selectDay(${prevDate.getFullYear()},${prevDate.getMonth()},${prevDate.getDate()})">${prevDate.getDate()}</div>`; }
    for (let d=1; d<=daysInMonth; d++) { const cur = new Date(year, month, d); let cls = 'date-day'; if (isSameDay(cur, today)) cls += ' today'; const s = dateState.start, e = dateState.end; if (s && isSameDay(cur, s) && e) cls += ' range-start'; else if (e && isSameDay(cur, e) && s) cls += ' range-end'; else if (s && isSameDay(cur, s)) cls += ' selected'; else if (s && e && cur > s && cur < e) cls += ' in-range'; html += `<div class="${cls}" onclick="selectDay(${year},${month},${d})">${d}</div>`; }
    html += `</div></div>`;
    return html;
  }
  function renderDatePicker() { const y = dateState.viewYear, m = dateState.viewMonth; const nextM = m===11?0:m+1; const nextY = m===11?y+1:y; document.getElementById('dateMonths').innerHTML = renderMonth(y,m)+renderMonth(nextY,nextM); }
  function toggleDatePicker() {
    const panel = document.getElementById('datePickerPanel');
    const cond  = document.getElementById('dateFilterCond');
    dateState.open = !dateState.open;
    if (dateState.open) {
      const rect = cond.getBoundingClientRect();
      panel.style.top  = (rect.bottom + 6) + 'px';
      panel.style.left = rect.left + 'px';
      if (rect.left + 580 > window.innerWidth - 12) panel.style.left = (window.innerWidth - 580 - 12) + 'px';
      panel.classList.add('open'); cond.classList.add('active'); renderDatePicker();
    } else { panel.classList.remove('open'); cond.classList.remove('active'); }
  }
  function closeDatePicker() { document.getElementById('datePickerPanel').classList.remove('open'); document.getElementById('dateFilterCond').classList.remove('active'); dateState.open = false; }
  function selectDay(y, m, d) { const clicked = new Date(y,m,d); if (!dateState.start||(dateState.start&&dateState.end)){dateState.start=clicked;dateState.end=null;} else { if (clicked<dateState.start){dateState.end=dateState.start;dateState.start=clicked;}else{dateState.end=clicked;} } renderDatePicker(); }
  function navMonth(dir) { dateState.viewMonth+=dir; if (dateState.viewMonth>11){dateState.viewMonth=0;dateState.viewYear++;} if (dateState.viewMonth<0){dateState.viewMonth=11;dateState.viewYear--;} renderDatePicker(); }
  function applyDate() { const textEl=document.getElementById('dateFilterText'); const cond=document.getElementById('dateFilterCond'); if (dateState.start&&dateState.end){textEl.textContent=`${fmtDate(dateState.start)} ~ ${fmtDate(dateState.end)}`;textEl.classList.add('has-value');cond.classList.add('has-value');} closeDatePicker(); }
  function cancelDate() { closeDatePicker(); }
  function clearDate(e) { e.stopPropagation(); dateState.start=dateState.end=null; const textEl=document.getElementById('dateFilterText'); const cond=document.getElementById('dateFilterCond'); textEl.textContent='Start Date ~ End Date'; textEl.classList.remove('has-value'); cond.classList.remove('has-value'); }
  function applyDateShortcut(key, el) { const today=new Date(); const d=n=>new Date(today.getFullYear(),today.getMonth(),today.getDate()-n); const presets={yesterday:[d(1),d(1)],last7:[d(6),d(0)],last30:[d(29),d(0)],lastWeek:[d(today.getDay()+7),d(today.getDay()+1)],lastMonth:[new Date(today.getFullYear(),today.getMonth()-1,1),new Date(today.getFullYear(),today.getMonth(),0)],thisMonth:[new Date(today.getFullYear(),today.getMonth(),1),d(0)],last90:[d(89),d(0)],lastYear:[new Date(today.getFullYear()-1,0,1),new Date(today.getFullYear()-1,11,31)]}; if (key==='custom') return; document.querySelectorAll('.date-shortcut').forEach(s=>s.classList.remove('selected')); el.classList.add('selected'); const [s,e]=presets[key]; dateState.start=s;dateState.end=e;dateState.viewYear=s.getFullYear();dateState.viewMonth=s.getMonth(); renderDatePicker(); }
  document.addEventListener('click', e => { if (!e.target.closest('#dateFilterCond')) closeDatePicker(); });

  /* ── 固定列横向滚动阴影 ─────────────────────────────────────── */
  (function initStickyColumnShadow() {
    document.querySelectorAll('.table-wrap').forEach(wrap => {
      function updateShadow() { const sl=wrap.scrollLeft; const max=wrap.scrollWidth-wrap.clientWidth; wrap.classList.toggle('can-scroll-right',sl<max-1); wrap.classList.toggle('can-scroll-left',sl>1); }
      wrap.addEventListener('scroll', updateShadow, { passive: true });
      requestAnimationFrame(updateShadow);
